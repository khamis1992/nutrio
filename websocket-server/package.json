{
  "name": "fleet-websocket-server",
  "version": "1.0.0",
  "description": "Fleet Management Portal WebSocket Real-time Tracking Server",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "websocket",
    "socket.io",
    "fleet-management",
    "real-time-tracking"
  ],
  "author": "Nutrio",
  "license": "MIT",
  "dependencies": {
    "socket.io": "^4.7.4",
    "@socket.io/redis-adapter": "^8.2.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}