# WebSocket Server Environment Variables
# Fleet Management Portal - Real-time Tracking

# ==================== SERVER CONFIG ====================
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ==================== REDIS CONFIG ====================
# Single Redis instance
REDIS_URL=redis://localhost:6379

# Redis Cluster (uncomment for cluster mode)
# REDIS_CLUSTER_MODE=true
# REDIS_CLUSTER_NODES=redis://redis-node-1:6379,redis://redis-node-2:6379,redis://redis-node-3:6379

# Redis options
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=fleet:

# ==================== DATABASE CONFIG ====================
# PostgreSQL/Supabase connection
DATABASE_URL=postgresql://user:password@localhost:5432/fleet_db
DATABASE_POOL_SIZE=20
DATABASE_SSL=false

# ==================== JWT CONFIG ====================
# Must match the JWT secret used by the main API
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ISSUER=fleet-management
JWT_AUDIENCE=fleet-websocket

# ==================== CORS CONFIG ====================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ==================== WEBSOCKET CONFIG ====================
# Maximum number of concurrent connections per server instance
WS_MAX_CONNECTIONS=10000

# Ping interval in milliseconds (25 seconds)
WS_PING_INTERVAL=25000

# Ping timeout in milliseconds (60 seconds)
WS_PING_TIMEOUT=60000

# Connection upgrade timeout in milliseconds
WS_UPGRADE_TIMEOUT=10000

# Per-message deflate compression
WS_PER_MESSAGE_DEFLATE=true

# ==================== LOCATION CACHE CONFIG ====================
# TTL for driver location cache in Redis (seconds)
LOCATION_CACHE_TTL=300

# TTL for driver status cache in Redis (seconds)
STATUS_CACHE_TTL=60

# Maximum location history to return per request
MAX_LOCATION_HISTORY_POINTS=1000

# ==================== RATE LIMITING ====================
# Minimum interval between location updates (milliseconds)
LOCATION_UPDATE_INTERVAL=5000

# Maximum location updates per minute per driver
MAX_LOCATION_UPDATES_PER_MINUTE=12

# ==================== MONITORING ====================
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable detailed metrics collection
ENABLE_METRICS=true

# Metrics reporting interval (seconds)
METRICS_INTERVAL=60
