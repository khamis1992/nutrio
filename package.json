{
  "name": "nutrio",
  "private": true,
  "version": "1.0.0",
  "description": "Nutrio - Healthy Meal Delivery & Nutrition Tracking",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "check": "node .opencode/scripts/enforce-patterns.js",
    "security:scan": "node scripts/security-static-audit.mjs",
    "check:all": "npm run typecheck && npm run lint && npm run test:run",
    "cap:sync": "cap sync",
    "cap:android": "npm run build && cap sync android && cap open android",
    "cap:ios": "npm run build && cap sync ios && cap open ios",
    "cap:sync:android": "cap sync android",
    "cap:sync:ios": "cap sync ios",
    "cap:dev:android": "npm run build && cap sync android && cap run android",
    "cap:dev:ios": "npm run build && cap sync ios && cap run ios",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:launch": "playwright test --config playwright.launch.config.ts",
    "test:cross-portal": "playwright test e2e/cross-portal/",
    "test:cross-portal:ui": "playwright test e2e/cross-portal/ --ui",
    "test:order-lifecycle": "playwright test e2e/cross-portal/order-lifecycle.spec.ts",
    "test:partner-onboarding": "playwright test e2e/cross-portal/partner-onboarding.spec.ts",
    "test:driver-delivery": "playwright test e2e/cross-portal/driver-delivery.spec.ts",
    "test:admin-management": "playwright test e2e/cross-portal/admin-management.spec.ts",
    "test:customer-journey": "playwright test e2e/cross-portal/customer-journey.spec.ts",
    "test:subscription-mgmt": "playwright test e2e/cross-portal/subscription-management.spec.ts",
    "test:affiliate-referral": "playwright test e2e/cross-portal/affiliate-referral.spec.ts",
    "test:wallet-payments": "playwright test e2e/cross-portal/wallet-payments.spec.ts",
    "test:payouts": "playwright test e2e/cross-portal/payouts-workflow.spec.ts",
    "test:notifications": "playwright test e2e/cross-portal/notifications-workflow.spec.ts"
  },
