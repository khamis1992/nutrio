PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173/nutrio

E2E_CUSTOMER_EMAIL=customer-e2e@example.com
E2E_CUSTOMER_PASSWORD=replace-with-a-dedicated-test-password
E2E_ADMIN_EMAIL=admin-e2e@example.com
E2E_ADMIN_PASSWORD=replace-with-a-dedicated-test-password
E2E_PARTNER_EMAIL=partner-e2e@example.com
E2E_PARTNER_PASSWORD=replace-with-a-dedicated-test-password
E2E_DRIVER_EMAIL=driver-e2e@example.com
E2E_DRIVER_PASSWORD=replace-with-a-dedicated-test-password
E2E_FLEET_EMAIL=fleet-e2e@example.com
E2E_FLEET_PASSWORD=replace-with-a-dedicated-test-password
E2E_SHARED_SCHEDULE_ID=replace-with-a-ready-schedule-assigned-to-the-test-driver
E2E_COACH_EMAIL=coach-e2e@example.com
E2E_COACH_PASSWORD=replace-with-a-dedicated-test-password

# The coach must have an active coach_client_assignments row for the customer.
# Both users must be able to read the same coach_programs and coach_messages rows.

# Set to 1 only when running the launch gate against a local frontend.
ALLOW_LOCAL_LAUNCH_GATE=0
