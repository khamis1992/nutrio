# Production Environment Variables Template
# Copy this file to .env.production and fill in the actual values

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
# Supabase hosted Edge Functions inject the named key maps automatically.
# Set these selectors only when using a key name other than "default".
NUTRIO_SUPABASE_PUBLISHABLE_KEY_NAME="default"
NUTRIO_SUPABASE_SECRET_KEY_NAME="default"

# App Configuration
VITE_APP_NAME="Nutrio"
VITE_APP_ID="com.nutrio.app"
# Public web URL used for email redirect links (important for native APK builds)
VITE_APP_URL="https://your-production-domain.com"

# Ultramsg WhatsApp API Credentials
VITE_ULTRAMSG_INSTANCE_ID="your-ultramsg-instance-id"
ULTRAMSG_TOKEN="your-ultramsg-token"

# Sadad Payment Gateway (Qatar)
VITE_SADAD_API_URL="https://api.sadad.qa"
VITE_SADAD_MERCHANT_ID="your-sadad-merchant-id"
SADAD_SECRET_KEY="your-sadad-secret-key"

# Supabase Edge Function server secret used only by an external renewal cron.
# Database pg_cron is preferred when available. Never expose this with VITE_.
SUBSCRIPTION_RENEWAL_CRON_SECRET="generate-a-long-random-secret"

# Security workers. Generate independent random values (at least 32 bytes)
# and store the same values in GitHub Environment secrets where scheduled
# workflows invoke these functions.
SECURITY_LOG_CRON_SECRET="generate-an-independent-long-random-secret"
WHATSAPP_PROCESSOR_CRON_SECRET="generate-an-independent-long-random-secret"
SUBSCRIPTION_RECOVERY_CRON_SECRET="generate-an-independent-long-random-secret"
MEAL_REMINDER_CRON_SECRET="generate-an-independent-long-random-secret"
ROLLOVER_CLEANUP_CRON_SECRET="generate-an-independent-long-random-secret"
AFFILIATE_NOTIFICATION_SECRET="generate-an-independent-long-random-secret"

# Daily tamper-evident ledger anchor. The webhook must be an independent,
# access-controlled HTTPS system (for example immutable object storage/SIEM).
SECURITY_ANCHOR_WEBHOOK_URL="https://security-evidence.example.com/nutrio/anchors"
SECURITY_ANCHOR_ALLOWED_HOSTS="security-evidence.example.com"
SECURITY_ANCHOR_HMAC_KEY="generate-at-least-32-random-bytes"

# Sensitive file malware scanning. Production defaults to fail closed.
# Scanner contract is documented in docs/security/DEPLOYMENT_SECURITY_CHECKLIST.md.
MALWARE_SCANNER_URL="https://scanner.example.com/v1/scan"
MALWARE_SCANNER_ALLOWED_HOSTS="scanner.example.com"
MALWARE_SCANNER_API_KEY="your-scanner-api-key"
REQUIRE_MALWARE_SCAN="true"

# Explicit browser/native origins allowed by Edge Function CORS.
APP_ALLOWED_ORIGINS="https://nutrio.me,https://www.nutrio.me,capacitor://localhost"
SPORTHUB_ALLOWED_HOSTS="sporthubapp.com"

# Resend Email Service (REQUIRED FOR PRODUCTION)
# Get from https://resend.com
RESEND_API_KEY="your-resend-api-key"

# Sentry Error Tracking (REQUIRED FOR PRODUCTION)
# Get from https://sentry.io
VITE_SENTRY_DSN="your-sentry-dsn"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# PostHog Analytics (REQUIRED FOR PRODUCTION)
# Get from https://posthog.com
VITE_POSTHOG_KEY="your-posthog-key"
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# App Version
VITE_APP_VERSION="1.0.0"

# OpenRouter AI API (For AI-Generated Reports)
# Get free API key from https://openrouter.ai
# Using free models: mistralai/mistral-7b-instruct:free or google/gemma-2-9b-it:free
OPENROUTER_API_KEY="your-openrouter-api-key"

# Mapbox (get from https://mapbox.com)
VITE_MAPBOX_TOKEN="your-mapbox-token"
